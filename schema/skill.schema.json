{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/castrojo/cncf-skills/schema/skill.schema.json",
  "title": "CNCF Skill Front-Matter",
  "description": "Schema for the YAML front-matter block in CNCF skill files",
  "type": "object",
  "required": ["id", "title", "version", "domain", "cncf_requirement", "applies_to", "template_source"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Stable kebab-case identifier"
    },
    "title": {
      "type": "string",
      "minLength": 5
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Semantic version"
    },
    "domain": {
      "type": "string",
      "enum": ["contribution", "governance", "security", "lifecycle"]
    },
    "cncf_requirement": {
      "type": "string",
      "enum": ["required", "encouraged", "optional"]
    },
    "applies_to": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["sandbox", "incubating", "graduated"]
      }
    },
    "template_source": {
      "type": "string",
      "format": "uri"
    },
    "how_to_guide": {
      "type": "string",
      "format": "uri"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
