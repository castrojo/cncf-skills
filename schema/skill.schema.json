{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/castrojo/cncf-skills/schema/skill.schema.json",
  "title": "CNCF Skill Front-Matter",
  "description": "Schema for the YAML front-matter block in CNCF skill files",
  "type": "object",
  "required": ["id", "description"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^_?[a-z][a-z0-9-]*$",
      "description": "Stable kebab-case identifier (leading underscore allowed for meta-skills)"
    },
    "description": {
      "type": "string",
      "minLength": 20,
      "maxLength": 1024,
      "description": "Third-person summary: what this skill does and when to use it. No first-person pronouns."
    },
    "template_source": {
      "type": "string",
      "format": "uri"
    },
    "how_to_guide": {
      "type": "string",
      "format": "uri"
    },
    "mcp_servers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "url"],
        "additionalProperties": false,
        "properties": {
          "id":          { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
          "description": { "type": "string", "minLength": 5 },
          "url":         { "type": "string", "format": "uri" }
        }
      }
    }
  }
}
